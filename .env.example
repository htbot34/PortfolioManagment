# All optional. Without either, the site falls back to rule-based recommendations.
# GitHub Actions sets GITHUB_TOKEN automatically with the workflow's `models: read`
# permission, so the hosted site uses LLM commentary for free with no extra config.

GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4o-mini

# REQUIRED for the SEC insider signal to work. SEC EDGAR rejects requests
# with placeholder / generic / non-deliverable User-Agents per its fair-access
# policy: https://www.sec.gov/os/accessing-edgar-data
# Set to a REAL monitored "Name email@domain". Do NOT use an example.com or
# @users.noreply.github.com address - SEC's CDN 403s those. In CI, set this as
# the SEC_USER_AGENT repository secret (see .github/workflows/refresh.yml).
# The build prints a loud startup warning while this is a placeholder.
SEC_USER_AGENT=YourName your.email@example.com

# How often to re-fetch sec.gov/files/company_tickers.json (cached at the repo
# root in ticker_cik_cache.json so it survives across CI runs). The map is
# near-static, so the TTL is LONG (days): a long TTL minimises live SEC hits,
# and resolution falls back to the cached map on any transient index outage.
CIK_CACHE_TTL_DAYS=30
