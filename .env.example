# All optional. Without either, the site falls back to rule-based recommendations.
# GitHub Actions sets GITHUB_TOKEN automatically with the workflow's `models: read`
# permission, so the hosted site uses LLM commentary for free with no extra config.

GITHUB_TOKEN=
GITHUB_MODEL=openai/gpt-4o-mini

# REQUIRED for the SEC insider signal to work. SEC EDGAR rejects requests
# with placeholder / generic User-Agents per its fair-access policy:
# https://www.sec.gov/os/accessing-edgar-data
# Set to your real name + email. Refresh.yml injects a per-repo value.
SEC_USER_AGENT=YourName your.email@example.com

# How often to re-fetch sec.gov/files/company_tickers.json (cached at the
# repo root in ticker_cik_cache.json so it survives across CI runs).
CIK_CACHE_TTL_DAYS=7
