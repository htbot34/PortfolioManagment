# Copy to .env and fill in. Both keys are optional for the dashboard to start,
# but news/sentiment and LLM research require them.

ANTHROPIC_API_KEY=
FINNHUB_API_KEY=

# Optional: override default models
CLAUDE_RESEARCH_MODEL=claude-opus-4-7
CLAUDE_SUMMARY_MODEL=claude-haiku-4-5-20251001

# SEC EDGAR requires a user agent identifying you per their fair-access policy.
SEC_USER_AGENT=PortfolioAdvisor research@example.com
